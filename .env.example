# Supabase publico / frontend
# El codigo actual usa VITE_SUPABASE_PUBLISHABLE_KEY.
# Si Supabase muestra "anon key", copia el mismo valor en la variable publishable.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_ANON_KEY=

# Supabase servidor / server functions
# El codigo actual usa SUPABASE_PUBLISHABLE_KEY para validar JWTs.
# SUPABASE_SERVICE_ROLE_KEY es secreta: nunca debe ser VITE_ ni exponerse al frontend.
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Desarrollo local solamente
# Apagado por defecto. No reemplaza Supabase Auth real ni prueba RLS real.
VITE_ENABLE_DEV_ADMIN=false
VITE_DEV_ADMIN_EMAIL=
VITE_DEV_ADMIN_PASSWORD=

# App
VITE_APP_NAME=Makrana Home Art
VITE_APP_ENV=local
